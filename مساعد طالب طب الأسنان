<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Dental Buddy Hub - رفيق عيادة الأسنان</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #f4f9f4;  /* خلفية طبية هادئة */
            font-family: 'Segoe UI', 'Tahoma', system-ui, -apple-system, sans-serif;
            color: #1a2e3a;
            line-height: 1.5;
            padding: 20px;
        }

        /* الحاوية الرئيسية */
        .app-container {
            max-width: 1400px;
            margin: 0 auto;
            background: #ffffff;
            border-radius: 32px;
            box-shadow: 0 20px 35px -10px rgba(0, 0, 0, 0.05);
            overflow: hidden;
        }

        /* الرأس */
        .header {
            background: linear-gradient(135deg, #e6f5ec 0%, #d0e9e0 100%);
            padding: 1.2rem 2rem;
            border-bottom: 1px solid #c3dec8;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .logo h1 {
            font-size: 1.8rem;
            font-weight: 700;
            background: linear-gradient(120deg, #1f6e43, #2b9e5e);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }

        .logo p {
            font-size: 0.8rem;
            color: #2e7d5e;
            font-weight: 500;
        }

        .user-badge {
            background: white;
            padding: 0.5rem 1.2rem;
            border-radius: 40px;
            display: flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.05);
        }

        .user-badge span:first-child {
            font-weight: bold;
            color: #1f6e43;
        }

        .lifetime-tag {
            background: #ffd966;
            padding: 4px 12px;
            border-radius: 30px;
            font-size: 0.75rem;
            font-weight: bold;
            color: #5e3a00;
        }

        /* التنقل (تبويبات) */
        .tabs {
            display: flex;
            gap: 0.25rem;
            background: #f8fef9;
            padding: 0.5rem 2rem 0 2rem;
            border-bottom: 1px solid #e0f0e3;
        }

        .tab-btn {
            background: none;
            border: none;
            padding: 0.8rem 1.8rem;
            font-size: 1rem;
            font-weight: 600;
            color: #4a6a5e;
            cursor: pointer;
            border-radius: 30px 30px 0 0;
            transition: all 0.2s;
        }

        .tab-btn.active {
            background: white;
            color: #1f6e43;
            border-bottom: 3px solid #2b9e5e;
            box-shadow: 0 -2px 5px rgba(0,0,0,0.02);
        }

        /* محتوى التبويبات */
        .tab-content {
            display: none;
            padding: 2rem;
            animation: fade 0.25s ease;
        }

        .tab-content.active {
            display: block;
        }

        @keyframes fade {
            from { opacity: 0; transform: translateY(6px);}
            to { opacity: 1; transform: translateY(0);}
        }

        /* البطاقات */
        .card {
            background: #ffffff;
            border: 1px solid #e2f0e5;
            border-radius: 28px;
            padding: 1.5rem;
            margin-bottom: 1.8rem;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.02);
            transition: box-shadow 0.2s;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid #def0e2;
            padding-bottom: 0.75rem;
            margin-bottom: 1.2rem;
        }

        .card-header h3 {
            color: #1f6e43;
            font-weight: 700;
        }

        .btn-primary {
            background: #2b9e5e;
            border: none;
            padding: 0.6rem 1.4rem;
            border-radius: 40px;
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            font-size: 0.9rem;
        }

        .btn-primary:hover {
            background: #1f6e43;
            transform: scale(1.02);
        }

        .btn-outline {
            background: transparent;
            border: 1.5px solid #2b9e5e;
            padding: 0.5rem 1.2rem;
            border-radius: 40px;
            color: #1f6e43;
            font-weight: 600;
            cursor: pointer;
        }

        .table-patients {
            width: 100%;
            border-collapse: collapse;
        }

        .table-patients th, .table-patients td {
            padding: 0.75rem;
            text-align: right;
            border-bottom: 1px solid #ecf8ef;
        }

        .whatsapp-btn {
            background: #25D366;
            color: white;
            border: none;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.7rem;
            cursor: pointer;
        }

        /* المساعد الذكي */
        .chat-assistant {
            background: #f9fefb;
            border-radius: 24px;
            padding: 1rem;
            border: 1px solid #cbe5d4;
        }

        .chat-messages {
            background: white;
            border-radius: 20px;
            padding: 1rem;
            min-height: 200px;
            max-height: 280px;
            overflow-y: auto;
            margin-bottom: 1rem;
        }

        .message {
            margin: 10px 0;
            display: flex;
            gap: 10px;
        }

        .message.user {
            justify-content: flex-end;
        }

        .message.bot {
            justify-content: flex-start;
        }

        .bubble {
            max-width: 75%;
            padding: 10px 14px;
            border-radius: 22px;
            font-size: 0.9rem;
        }

        .user .bubble {
            background: #2b9e5e;
            color: white;
            border-bottom-left-radius: 6px;
        }

        .bot .bubble {
            background: #eef6f1;
            color: #1e3b32;
            border-bottom-right-radius: 6px;
        }

        /* لوحة المسؤول */
        .admin-panel {
            background: #fefaf0;
            border: 1px solid #f2e6c7;
        }
        .user-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.8rem 0;
            border-bottom: 1px solid #e3e9e2;
        }
        .suspend-btn {
            background: #e76f51;
            color: white;
            border: none;
            padding: 4px 12px;
            border-radius: 30px;
            margin-left: 8px;
            cursor: pointer;
        }
        .activate-btn {
            background: #2b9e5e;
            color: white;
            border: none;
            padding: 4px 12px;
            border-radius: 30px;
            cursor: pointer;
        }
        .pill-status {
            font-size: 0.7rem;
            background: #e9ecef;
            padding: 2px 8px;
            border-radius: 30px;
        }

        /* خطة الاشتراك */
        .plan-card {
            background: linear-gradient(135deg, #f1fcf5, #ffffff);
            border: 2px solid #2b9e5e30;
            border-radius: 32px;
            padding: 1.5rem;
            text-align: center;
        }
        .price {
            font-size: 2.5rem;
            font-weight: 800;
            color: #1f6e43;
        }

        footer {
            background: #eaf6ef;
            text-align: center;
            padding: 1rem;
            font-size: 0.75rem;
            color: #4a6e5d;
        }

        @media (max-width: 700px) {
            .tabs { padding: 0 1rem; }
            .tab-btn { padding: 0.5rem 1rem; font-size: 0.8rem; }
            .tab-content { padding: 1rem; }
        }
    </style>
</head>
<body>
<div class="app-container">
    <div class="header">
        <div class="logo">
            <h1>🦷 Dental Buddy Hub</h1>
            <p>رفيقك الذكي في عيادة الأسنان | إدارة · مساعد طوارئ · واتساب</p>
        </div>
        <div class="user-badge">
            <span>أحمد المنصوري</span>
            <span class="lifetime-tag">⭐ مدى الحياة ⭐</span>
            <span style="font-size:12px; color:#1f6e43;">✅ مفعل</span>
        </div>
    </div>

    <div class="tabs">
        <button class="tab-btn active" data-tab="dashboard">🏠 لوحة التحكم</button>
        <button class="tab-btn" data-tab="patients">📋 سجل المرضى</button>
        <button class="tab-btn" data-tab="assistant">🚨 المساعد الذكي للطوارئ</button>
        <button class="tab-btn" data-tab="admin">⚙️ لوحة الإدارة (مشرف)</button>
    </div>

    <!-- لوحة التحكم الرئيسية -->
    <div class="tab-content active" id="dashboard">
        <div class="card">
            <div class="card-header">
                <h3>📊 ملخص يومك السريري</h3>
                <span class="pill-status">آخر تحديث: اليوم 10:30 ص</span>
            </div>
            <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
                <div style="flex:1; background:#eef6f1; border-radius: 24px; padding: 1rem;">
                    <h4>🦷 مرضى اليوم</h4>
                    <p style="font-size:2rem; font-weight:bold;">4</p>
                    <small>الجلسات المتبقية: 2</small>
                </div>
                <div style="flex:1; background:#eef6f1; border-radius: 24px; padding: 1rem;">
                    <h4>📨 رسائل واتساب مرسلة</h4>
                    <p style="font-size:2rem; font-weight:bold;">12</p>
                    <small>هذا الأسبوع</small>
                </div>
                <div style="flex:1; background:#fff2e0; border-radius: 24px; padding: 1rem;">
                    <h4>🚨 حالات الطوارئ (المساعد)</h4>
                    <p style="font-size:2rem; font-weight:bold;">3</p>
                    <small>تم حلها جميعاً</small>
                </div>
            </div>
        </div>
        <div class="plan-card">
            <h3>🔥 اشتراك مدى الحياة · دفعة واحدة</h3>
            <div class="price">$5</div>
            <p>تتمتع بجميع الميزات: إدارة غير محدودة للمرضى، مساعد طوارئ ذكي محلي، إرسال واتساب تلقائي، تقارير أسبوعية، واستدعاء مشرفين.</p>
            <button class="btn-primary" id="fakePayBtn" style="margin-top: 1rem;">✨ قمت بالدفع مسبقاً (مفعل) ✨</button>
            <p style="font-size: 0.7rem; margin-top: 10px;">✔ حسابك مفعل مدى الحياة – لن تحتاج للدفع مجدداً</p>
        </div>
    </div>

    <!-- سجل المرضى - وحدة إدارة المرضى مع واتساب -->
    <div class="tab-content" id="patients">
        <div class="card">
            <div class="card-header">
                <h3>➕ إضافة مريض جديد (يدوياً)</h3>
                <button class="btn-primary" id="showAddPatientFormBtn" style="background:#4a90e2;">إضافة مريض</button>
            </div>
            <div id="addPatientForm" style="display:none; background:#fafefa; padding:1rem; border-radius:24px; margin-bottom:1rem;">
                <input type="text" id="patName" placeholder="الاسم الكامل" style="padding:8px; margin-left:8px; border-radius:20px; border:1px solid #ccc;">
                <input type="tel" id="patPhone" placeholder="رقم واتساب (مثال 9665xxxxxxx)" style="padding:8px; margin-left:8px; border-radius:20px; border:1px solid #ccc;">
                <input type="text" id="patDiagnosis" placeholder="التشخيص / الخطة" style="padding:8px; border-radius:20px; border:1px solid #ccc;">
                <button id="savePatientBtn" class="btn-primary" style="margin-top:8px;">حفظ المريض</button>
            </div>
            <h3>📋 قائمة مرضاي</h3>
            <table class="table-patients" id="patientsTable">
                <thead>
                    <tr><th>الاسم</th><th>التشخيص</th><th>رقم واتساب</th><th>موعد قادم</th><th>إجراء</th></tr>
                </thead>
                <tbody id="patientsList">
                    <tr><td>سعاد محمد</td><td>قلع ضرس العقل</td><td>+966 5xxxxxx01</td><td>الخميس 11 ص</td><td><button class="whatsapp-btn" onclick="alert('🚀 سيتم فتح واتساب مع تذكير للمريضة')">📱 تذكير واتساب</button></td></tr>
                    <tr><td>خالد المالكي</td><td>حشو عصب (جلسة 2)</td><td>+966 5xxxxxx34</td><td>الأحد 9 ص</td><td><button class="whatsapp-btn" onclick="alert('رسالة تذكير للمريض: موعدك الأحد الساعة 9')">إرسال تذكير</button></td></tr>
                </tbody>
            </table>
            <div style="margin-top: 1rem;">
                <button class="btn-outline" onclick="alert('📨 تم فتح واتساب لإرسال تذكير جماعي (محاكاة). في التطبيق الحقيقي ستظهر القائمة.')">📢 إرسال تذكير جماعي (واتساب)</button>
            </div>
        </div>
    </div>

    <!-- المساعد الذكي للطوارئ (محلي عالي الحساسية) -->
    <div class="tab-content" id="assistant">
        <div class="card">
            <div class="card-header">
                <h3>🚨 المساعد الذكي للطوارئ · يعمل بدون إنترنت · فصحى وعامية</h3>
                <span class="pill-status">⚡ خوارزمية مطابقة فائقة الحساسية</span>
            </div>
            <div class="chat-assistant">
                <div class="chat-messages" id="chatMessages">
                    <div class="message bot">
                        <div class="bubble">مرحباً، أنا مساعد الطوارئ الذكي. صِف لي المشكلة (نزيف، إغماء، كسر أداة، حساسية، الخ). أنا أدعم العامية والفصحى.</div>
                    </div>
                </div>
                <div style="display: flex; gap: 8px;">
                    <input type="text" id="emergencyInput" placeholder="مثال: المريض ينزف بقوة بعد قلع الضرس..." style="flex:1; padding:12px; border-radius: 60px; border:1px solid #cbe5d4;">
                    <button id="sendEmergencyBtn" class="btn-primary">🔍 طلب مساعدة</button>
                </div>
                <div style="margin-top: 10px; display: flex; gap: 8px; flex-wrap: wrap;">
                    <button class="btn-outline" data-quick="نزيف بعد القلع">🩸 نزيف بعد القلع</button>
                    <button class="btn-outline" data-quick="المريض وقع وغاب عن الوعي">😵 إغماء</button>
                    <button class="btn-outline" data-quick="الأبرة اتكسرت جوه الفم">⚠️ كسر إبرة تخدير</button>
                    <button class="btn-outline" data-quick="حساسية من اللاتكس تورم بالشفايف">🤚 حساسية لاتكس</button>
                </div>
            </div>
            <p style="font-size:0.7rem; margin-top:12px;">🧠 يعمل محلياً على هاتفك، يتعرف على الكلمات المفتاحية بالعامية السعودية والمصرية وغيرها، ويقدم خطوات فورية دقيقة.</p>
        </div>
        <div class="card">
            <h3>📋 آخر حالات الطوارئ المسجلة</h3>
            <ul style="list-style: none;">
                <li>✅ 22/4 - نزيف خفيف، تم تطبيق الضغط &nbsp;<span style="color:green;">تم الحل</span></li>
                <li>✅ 21/4 - مريض إغماء، المساعد وجه باستدعاء مشرف وتم الإفاقة</li>
            </ul>
        </div>
    </div>

    <!-- لوحة الإدارة (تفعيل و ترقين الحسابات) -->
    <div class="tab-content" id="admin">
        <div class="card admin-panel">
            <div class="card-header">
                <h3>🔐 صلاحية المسؤول: تفعيل · ترقين الحسابات</h3>
                <span>🔑 أنت logged in as admin@dentalbuddy.com</span>
            </div>
            <p>إدارة اشتراكات الطلاب (دفعة واحدة 5$ مدى الحياة) وتعطيل المخالفين.</p>
            <div id="usersListAdmin">
                <!-- سيتم عرض مستخدمين تجريبيين مع تفعيل/ترقين -->
                <div class="user-row" data-uid="user1">
                    <div><strong>سلمى الغامدي</strong> - s@g.com <span class="pill-status" id="status_user1">مفعل · lifetime ✅</span></div>
                    <div><button class="suspend-btn" onclick="toggleUserStatus('user1','suspend')">🔴 ترقين (تعطيل)</button>
                    <button class="activate-btn" onclick="toggleUserStatus('user1','activate')">🟢 تفعيل</button></div>
                </div>
                <div class="user-row" data-uid="user2">
                    <div><strong>عبدالله الناصر</strong> - a@nasser.com <span class="pill-status" id="status_user2">مُرقن (محظور) ⚠️</span></div>
                    <div><button class="suspend-btn" onclick="toggleUserStatus('user2','suspend')">ترقين</button>
                    <button class="activate-btn" onclick="toggleUserStatus('user2','activate')">تفعيل</button></div>
                </div>
                <div class="user-row" data-uid="user3">
                    <div><strong>نورة السبيعي</strong> - nora@dental.com <span class="pill-status" id="status_user3">تجربة (غير مفعل lifetime)</span></div>
                    <div><button class="activate-btn" onclick="activateLifetime('user3')">💎 تفعيل Lifetime (5$)</button>
                    <button class="suspend-btn" onclick="toggleUserStatus('user3','suspend')">ترقين</button></div>
                </div>
            </div>
            <div class="card-header" style="margin-top: 20px;">
                <h3>📜 سجل الإجراءات (آخر العمليات)</h3>
            </div>
            <ul id="adminLogs">
                <li>المسؤول (أحمد) فعّل الاشتراك مدى الحياة لـ سلمى بتاريخ 24-4-2026</li>
                <li>تم ترقين حساب عبدالله بسبب الإساءة في استخدام المساعد الذكي</li>
            </ul>
            <p style="font-size:0.7rem; margin-top:10px;">* عند ترقين المستخدم يفقد الوصول الكامل للتطبيق، وعند تفعيل lifetime تظهر الميزات بدون حدود.</p>
        </div>
    </div>
    <footer>
        Dental Buddy Hub v1.0 | نظام اشتراك مدى الحياة بقيمة 5$ فقط | خوارزميات محلية فائقة الحساسية | 🧾 لوحة الإدارة بصلاحية تفعيل/ترقين
    </footer>
</div>

<script>
    // ادارة التبويبات
    const tabs = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');
    tabs.forEach(btn => {
        btn.addEventListener('click', () => {
            const tabId = btn.getAttribute('data-tab');
            contents.forEach(c => c.classList.remove('active'));
            document.getElementById(tabId).classList.add('active');
            tabs.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
        });
    });

    // اضافة مريض (محاكاة)
    const showFormBtn = document.getElementById('showAddPatientFormBtn');
    const formDiv = document.getElementById('addPatientForm');
    if(showFormBtn) {
        showFormBtn.addEventListener('click', () => {
            formDiv.style.display = formDiv.style.display === 'none' ? 'block' : 'none';
        });
    }
    const saveBtn = document.getElementById('savePatientBtn');
    if(saveBtn) {
        saveBtn.addEventListener('click', () => {
            const name = document.getElementById('patName').value;
            const phone = document.getElementById('patPhone').value;
            const diag = document.getElementById('patDiagnosis').value;
            if(name && phone) {
                const tbody = document.getElementById('patientsList');
                const row = tbody.insertRow();
                row.innerHTML = `<td>${name}</td><td>${diag || 'لايوجد'}</td><td>${phone}</td><td>يحدد لاحقاً</td><td><button class="whatsapp-btn" onclick="alert('📱 سيتم فتح واتساب لتذكير ${name}')">📱 تذكير واتساب</button></td>`;
                document.getElementById('patName').value = '';
                document.getElementById('patPhone').value = '';
                document.getElementById('patDiagnosis').value = '';
                formDiv.style.display = 'none';
            } else alert('يرجى إدخال الاسم ورقم الهاتف');
        });
    }

    // ++++++++++ المساعد الذكي (محاكاة ذكاء محلي عالي الحساسية) ++++++++++
    const emergencyKeywords = [
        { keywords: ["نزيف", "ينزف", "دم", "دمعة", "خناقة دم", "نزف"], steps: "🩸 الخطوات: اضغط بشاش معقم لمدة 5 دقائق. إذا استمر النزيف، استخدم إسفنجة جيلاتين. تجنب المضمضة. هل يتناول مميعات دم؟", supervisor: "إذا استمر النزيف >20 دقيقة استدع مشرفاً." },
        { keywords: ["اغمى", "غاب عن الوعي", "وقع", "فقد وعيه", "إغماء"], steps: "😵 إغماء: أرخِ الملابس، ارفع الرجلين لأعلى، فتح المجرى الهوائي، نادِ مشرفاً فوراً.", supervisor: "اطلب المساعدة الطبية فوراً." },
        { keywords: ["الأبرة اتكسرت", "كسر إبرة", "إبرة مكسورة", "break needle"], steps: "⚠️ كسر إبرة التخدير: لا تحاول الإخراج بالأصابع، ثبّت المريض، استخدم ملقط معقم إذا ظاهر، استدع مشرفاً فوراً وأشعة.", supervisor: "استدعاء جراح فوري." },
        { keywords: ["حساسية", "لاتكس", "تورم", "حكة", "طفح"], steps: "🤚 حساسية اللاتكس: أزل القفازات فوراً، استخدم قفازات خالية من اللاتكس، أعط مضاد هيستامين إذا متوفر، وراقب التنفس.", supervisor: "استدع مشرفاً للحالات الشديدة." },
        { keywords: ["كسر تاج", "كسر سن", "تجزأ السن", "جزء من السن"], steps: "🦷 كسر سني: اشطف الفم بماء دافئ، احفظ القطعة في حليب بارد، غطِّ المنطقة بشاش، توجه لعيادة الطوارئ.", supervisor: "اتصل بالمشرف لترتيب أشعة." }
    ];
    function smartAssistant(userText) {
        userText = userText.toLowerCase();
        let bestMatch = null;
        let maxScore = 0;
        for(let pattern of emergencyKeywords) {
            let score = 0;
            for(let kw of pattern.keywords) {
                if(userText.includes(kw)) {
                    score += kw.length > 2 ? 2 : 1;
                }
            }
            if(score > maxScore) {
                maxScore = score;
                bestMatch = pattern;
            }
        }
        if(bestMatch && maxScore > 0) {
            return `🚨 **توصية دقيقة** 🚨\n${bestMatch.steps}\n\n⚠️ ملاحظة: ${bestMatch.supervisor}\n\n(بناءً على كلماتك: "${userText.slice(0,50)}")`;
        } else {
            return "لم أتعرف على الحالة بدقة. يرجى كتابة المزيد من التفاصيل (مثال: نزيف، الم حاد، كسر أداة). إذا كانت حالة طارئة حقيقية، اتصل بالمشرف فوراً. 🏥";
        }
    }
    const chatContainer = document.getElementById('chatMessages');
    function addMessage(text, isUser) {
        const msgDiv = document.createElement('div');
        msgDiv.className = `message ${isUser ? 'user' : 'bot'}`;
        const bubble = document.createElement('div');
        bubble.className = 'bubble';
        bubble.innerHTML = text.replace(/\n/g,'<br>');
        msgDiv.appendChild(bubble);
        chatContainer.appendChild(msgDiv);
        chatContainer.scrollTop = chatContainer.scrollHeight;
    }
    const sendBtn = document.getElementById('sendEmergencyBtn');
    const inputEmerg = document.getElementById('emergencyInput');
    function processUserMessage(text) {
        if(!text.trim()) return;
        addMessage(text, true);
        const response = smartAssistant(text);
        addMessage(response, false);
        inputEmerg.value = '';
    }
    if(sendBtn) {
        sendBtn.addEventListener('click', () => processUserMessage(inputEmerg.value));
        inputEmerg.addEventListener('keypress', (e) => { if(e.key === 'Enter') processUserMessage(inputEmerg.value); });
    }
    document.querySelectorAll('[data-quick]').forEach(btn => {
        btn.addEventListener('click', (e) => {
            const txt = btn.getAttribute('data-quick');
            processUserMessage(txt);
        });
    });

    // ******************* لوحة الإدارة: وظائف التفعيل والترقين (محاكاة) *******************
    window.toggleUserStatus = (userId, action) => {
        const statusSpan = document.getElementById(`status_${userId}`);
        if(!statusSpan) return;
        if(action === 'suspend') {
            statusSpan.innerText = 'مُرقن (محظور) ⚠️';
            statusSpan.style.color = '#b33';
            alert(`🔴 تم ترقين (تعطيل) المستخدم ${userId} . لن يتمكن من استخدام التطبيق.`);
            addLog(`تم ترقين ${userId} بواسطة المسؤول.`);
        } else if(action === 'activate') {
            statusSpan.innerText = 'مفعل · lifetime ✅';
            statusSpan.style.color = '#1f6e43';
            alert(`🟢 تم تفعيل الحساب (إذا كان الاشتراك ساريًا).`);
            addLog(`تم تفعيل حساب ${userId} .`);
        }
    };
    window.activateLifetime = (userId) => {
        const statusSpan = document.getElementById(`status_${userId}`);
        if(statusSpan) {
            statusSpan.innerText = 'مفعل · lifetime ✅';
            statusSpan.style.color = '#1f6e43';
            alert(`✨ تم تفعيل الاشتراك مدى الحياة للمستخدم ${userId} (دفعة 5$).`);
            addLog(`✨ تفعيل Lifetime للمستخدم ${userId} بعد الدفع.`);
        }
    };
    function addLog(msg) {
        const logList = document.getElementById('adminLogs');
        const li = document.createElement('li');
        li.textContent = `[${new Date().toLocaleTimeString()}] ${msg}`;
        logList.prepend(li);
    }
    // محاكاة دفع الـ lifetime فى لوحة التحكم
    document.getElementById('fakePayBtn')?.addEventListener('click', () => {
        alert("✅ حسابك الحالي مفعل مدى الحياة (لقد قمت بالدفع مسبقاً) . تمتلك جميع الميزات إلى الأبد.");
    });
    // إضافة مبدئية لتنبيه واتساب تجريبي
    window.sendWhatsappDemo = (name) => {
        alert(`📲 فتح واتساب مع المريض: ${name} - رسالة تذكير جاهزة.`);
    };
</script>
</body>
